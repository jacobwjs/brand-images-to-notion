# Copy this file to ".env" and fill in what you need. Never commit the real .env.

# ── Image generation (pick at least one) ──────────────────────────────────────
# Option A — OpenAI Images API (recommended; simplest setup).
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Option B — Codex CLI backend instead. No key goes here; just run `codex login`
# once in a terminal. Then call generate_brand_image with backend="codex".

# ── Notion upload (required to push images into Notion) ───────────────────────
# 1. Create an internal integration: https://www.notion.so/my-integrations
# 2. Copy its "Internal Integration Secret" (starts with ntn_).
# 3. Share your target Notion page with the integration:
#    open the page -> ••• menu -> Connections -> add your integration.
NOTION_TOKEN=
